{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/sync/youtube",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/sync/meta",
      "schedule": "0 0 * * *"
    }
  ]
}
